	author = {Bermingham, Kate M. and Linenberg, Inbar and Polidori, Lorenzo and Asnicar, Francesco and Arrè, Alberto and Wolf, Jonathan and Badri, Fatema and Bernard, Hannah and Capdevila, Joan and Bulsiewicz, William J. and Gardner, Christopher D. and Ordovas, Jose M. and Davies, Richard and Hadjigeorgiou, George and Hall, Wendy L. and Delahanty, Linda M. and Valdes, Ana M. and Segata, Nicola and Spector, Tim D. and Berry, Sarah E.},
	month = jul,
	year = {2024},
	pages = {1888--1897},
	file = {PDF:files/33/Bermingham et al. - 2024 - Effects of a personalized nutrition program on cardiometabolic health a randomized controlled trial.pdf:application/pdf},
